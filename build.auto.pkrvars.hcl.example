aws_region   = "us-gov-west-1"
builder_name = "packer-rhel8-builder"

source_ami = "ami-xxxxxxxxxxxxxxxxx"

subnet_id = "subnet-xxxxxxxxxxxxxxxxx"
security_group_ids = [
  "sg-xxxxxxxxxxxxxxxxx",
  "sg-yyyyyyyyyyyyyyyyy",
]

instance_type = "t3.medium"

ami_name_prefix = "rhel8-vsphere-test"

ssh_private_key_file = "/secure/path/to/inherited-builder-key.pem"
